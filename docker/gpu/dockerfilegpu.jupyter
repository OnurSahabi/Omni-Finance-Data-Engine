FROM rapidsai/notebooks:25.02-cuda12.8-py3.11

USER root

RUN apt-get update && \
    apt-get install -y openjdk-17-jdk && \
    rm -rf /var/lib/apt/lists/*

ENV JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64

ENV JUPYTER_SERVER_ROOT=/tmp

USER rapids

RUN pip install --no-cache-dir \
    pyspark==4.0.0 \
    pandas==2.2.2 \
    numpy \
    scipy \
    qpsolvers \
    quadprog \
    matplotlib \
    seaborn \
    plotly \
    networkx \
    community \
    scikit-learn

